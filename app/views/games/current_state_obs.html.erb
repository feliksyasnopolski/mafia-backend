<!DOCTYPE html>
<html>
  <head>
    <title>MafiaBackend</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_include_tag "application", "data-turbo-track": "reload", type: "module" %>
  </head>

  <body>
    <style>
      .card-body {
      background-color: darkgrey;
      }

      .card-body img {
      width: -webkit-fill-available;
      }
    </style>
    </style>
    <div class="card-group">
      <% @players.each do |game_player| %>
        <div class="card" style="width: 8rem;">
          <div class="card-body">
            <h5 class="card-title"><%= game_player.player.nickname %></h5>
            <%= image_tag(game_player.player.avatar) if game_player.player.avatar.present? %>
            <p class="card-text"><%= game_player.alive ? "Живой" : "Убит" %></p>
          </div>
        </div>
      <% end %>
    </div>
  </body>

  <script>
    setInterval(function() {
      location.reload();
    }, 1000);
  </script>
</html>
